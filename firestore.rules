rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isAdmin() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super';
    }

    match /admins/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow list, create, update, delete: if isSuperAdmin();
    }

    match /portfolioOwner/profile {
      allow get, list: if true;
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /messages/{messageId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    match /{collection}/{docId} {
      allow get, list: if true;
      allow create, update: if isAdmin() && (collection != 'admins');
      allow delete: if isSuperAdmin();
    }
  }
}