/**
 * KaryaPro Production-Grade Security Rules
 * 
 * Access Model:
 * - Public: Read-only access to all content.
 * - Editor: Create and Update access (for projects, certs, etc.)
 * - Super Admin: Full CRUD access including Delete and User Management.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getAdminData() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isAdmin() && getAdminData().role == 'super';
    }

    // --- Rules ---

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isSuperAdmin();
    }

    match /portfolioOwner/profile {
      allow get, list: if true;
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /{collection}/{docId} {
      // Logic for all content collections (projects, certificates, etc.)
      allow get, list: if true;
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}