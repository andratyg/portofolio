{
  "entities": {
    "PortfolioOwner": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PortfolioOwner",
      "type": "object",
      "description": "Represents the individual who owns and manages the portfolio.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "aboutMeId": { "type": "string" },
        "aboutMeEn": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "whatsAppNumber": { "type": "string" },
        "linkedInProfileUrl": { "type": "string", "format": "uri" },
        "githubProfileUrl": { "type": "string", "format": "uri" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "totalProjectsCompleted": { "type": "number" },
        "codingExperienceYears": { "type": "number" },
        "totalTechnologiesMastered": { "type": "number" }
      },
      "required": ["id", "name", "email"]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "titleId": { "type": "string" },
        "titleEn": { "type": "string" },
        "shortDescriptionId": { "type": "string" },
        "shortDescriptionEn": { "type": "string" },
        "fullDescriptionId": { "type": "string" },
        "fullDescriptionEn": { "type": "string" },
        "mainImageUrl": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "titleId", "titleEn", "mainImageUrl"]
    },
    "ContactMessage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ContactMessage",
      "type": "object",
      "description": "Messages sent through the contact form.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "message", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/portfolioOwner/profile", "definition": { "entityName": "PortfolioOwner" } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project" } },
      { "path": "/certificates/{certificateId}", "definition": { "entityName": "Certificate" } },
      { "path": "/messages/{messageId}", "definition": { "entityName": "ContactMessage" } },
      { "path": "/admins/{adminId}", "definition": { "entityName": "Admin" } }
    ]
  }
}